# =============================================================================
# YNC Platform — Environment Variables (Server + Client)
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# For Vercel deployment: set ALL of these in your Vercel project dashboard
#   (Settings → Environment Variables).
# =============================================================================

# ========================
# SERVER-SIDE ENV VARS
# ========================

# --- Secrets (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))") ---
JWT_SECRET=9ce4c0c152b9a4fac7c796d02ac9ea4728a6dc17cdfd0af30368efd342f2e3eb
ADMIN_JWT_SECRET=9b25858085478757cd24bf139224bb4bbb06128408ab739f40058eea02038130

# --- VAPID Keys for Push Notifications (generate with: npx web-push generate-vapid-keys) ---
VAPID_PUBLIC_KEY=BOreqXQopTly4NlzcjFf51PYGxhgp61FRjhj16LtdOFiTTGOevb_MK2bi9MyRXVNVfGqgF80fNpDNJeUYJs36xI
VAPID_PRIVATE_KEY=GDjli6PWrO5JxfAPNVoIVZdPz9lpH8u0fVBcQbQgXtY

# --- Server ---
PORT=5000
NODE_ENV=production
SERVERLESS=0
ENABLE_SOCKET=true
CRON_SECRET=generate_a_long_random_secret_for_vercel_cron

# --- Firebase (choose ONE method) ---
# Option A: Path to service account JSON file (local dev)
# GOOGLE_APPLICATION_CREDENTIALS=./server/config/firebase-key.json
# Option B: Paste entire service account JSON as a string (Vercel)
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account",...}
# Firebase Storage bucket used for persistent uploads on Vercel
FIREBASE_STORAGE_BUCKET=ync-patform.firebasestorage.app

# --- CORS (set to your frontend domain in production) ---
# CORS_ORIGIN=https://yourdomain.vercel.app

# ========================
# CLIENT-SIDE VITE ENV VARS
# ========================
# These MUST be prefixed with VITE_ and set in Vercel dashboard.
# ⚠️ On Vercel, Prefix each client var with "VITE_" in the dashboard.

# --- Firebase Client Config (from Firebase Console → Project Settings → Web App) ---
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abc123

# --- Optional Client Config ---
# Disable Socket.io on Vercel (WebSockets don't work on serverless)
VITE_ENABLE_SOCKET=true
# VAPID public key for push notifications (same as server-side VAPID_PUBLIC_KEY)
VITE_VAPID_PUBLIC_KEY=
# Explicit API URL (optional — defaults to current origin)
# VITE_API_URL=https://yourdomain.vercel.app
