# =============================================================================
# YNC Client — Vite Environment Variables
# =============================================================================
# Copy this file to .env and fill in the VAPID public key (same as server):
#   cp .env.example .env
#
# VITE_ prefix is required for Vite to expose these to client code.
# =============================================================================

# VAPID public key for push notifications (must match server's VAPID_PUBLIC_KEY)
VITE_VAPID_PUBLIC_KEY=BOreqXQopTly4NlzcjFf51PYGxhgp61FRjhj16LtdOFiTTGOevb_MK2bi9MyRXVNVfGqgF80fNpDNJeUYJs36xI

# Optional: API URL override. Defaults to http://localhost:5000 in dev.
# In production when Express serves both API and frontend, this is inferred from the current origin.
# Only set if your API is on a separate domain.
# VITE_API_URL=https://api.yourdomain.com
