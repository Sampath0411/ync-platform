{
  "version": 2,
  "buildCommand": "npm install && npm --prefix server install && npm --prefix client install --include=dev && npm --prefix client run build",
  "outputDirectory": "client/dist",
  "functions": {
    "api/index.js": {
      "maxDuration": 30,
      "includeFiles": "server/**"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index" },
    { "source": "/s/(.*)", "destination": "/api/index" },
    { "source": "/((?!api/|s/|assets/|favicon.ico|manifest.json|sw.js).*)", "destination": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/cron/membership-expiry",
      "schedule": "0 3 * * *"
    }
  ]
}
